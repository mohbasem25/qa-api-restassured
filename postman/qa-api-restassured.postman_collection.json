  "item": [
    {
      "name": "Users - Read",
      "item": [
        {
          "name": "List users - skip 0",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 200', function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "",
                  "pm.test('Response time is below 3000ms', function () {",
                  "    pm.expect(pm.response.responseTime).to.be.below(3000);",
                  "});",
                  "",
                  "pm.test('Content-Type header is JSON', function () {",
                  "    pm.expect(pm.response.headers.get('Content-Type')).to.include('application/json');",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test('skip field equals 0', function () {",
                  "    pm.expect(jsonData.skip).to.eql(0);",
                  "});",
                  "",
                  "pm.test('users array is not empty', function () {",
                  "    pm.expect(jsonData.users).to.be.an('array').that.is.not.empty;",
                  "});",
                  "",
                  "pm.test('each user has required fields', function () {",
                  "    jsonData.users.forEach(function (user) {",
                  "        pm.expect(user).to.have.property('id');",
                  "        pm.expect(user).to.have.property('email');",
                  "        pm.expect(user).to.have.property('firstName');",
                  "        pm.expect(user).to.have.property('lastName');",
                  "        pm.expect(user).to.have.property('image');",
                  "    });",
                  "});",
                  "",
                  "var schema = {",
                  "    type: 'object',",
                  "    required: ['total', 'skip', 'limit', 'users'],",
                  "    properties: {",
                  "        total: { type: 'integer' },",
                  "        skip: { type: 'integer' },",
                  "        limit: { type: 'integer' },",
                  "        users: { type: 'array' }",
                  "    }",
                  "};",
                  "",
                  "pm.test('response matches list-users schema', function () {",
                  "    pm.expect(tv4.validate(jsonData, schema)).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users?limit=10&skip=0",
              "host": ["{{baseUrl}}"],
              "path": ["users"],
              "query": [
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "skip",
                  "value": "0"
                }
              ]
            },
            "description": "Retrieves the first page (skip=0) of the paginated users list."
          },
          "response": []
        },
