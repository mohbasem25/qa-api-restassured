    {
      "name": "Users - Write (chained)",
      "item": [
        {
          "name": "Create user (simulated)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test('response echoes submitted firstName and lastName', function () {",
                  "    pm.expect(jsonData.firstName).to.eql('Morpheus');",
                  "    pm.expect(jsonData.lastName).to.eql('Leader');",
                  "});",
                  "",
                  "pm.test('id is present', function () {",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "});",
                  "",
                  "// Chain the (simulated, non-persisted) created user id into an",
                  "// environment variable for reuse by the Update/Delete requests",
                  "// below -- narratively mirrors a real create->update->delete flow,",
                  "// even though dummyjson.com does not actually persist the record.",
                  "pm.environment.set('createdUserId', jsonData.id);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n    \"firstName\": \"Morpheus\",\n    \"lastName\": \"Leader\"\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            },
            "url": {
              "raw": "{{baseUrl}}/users/add",
              "host": ["{{baseUrl}}"],
              "path": ["users", "add"]
            }
          },
          "response": []
        },
