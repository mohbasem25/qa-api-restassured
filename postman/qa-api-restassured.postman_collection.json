                  "    pm.expect(jsonData.lastName).to.eql('Anderson');",
                  "});",
                  "",
                  "pm.test('id matches the updated user', function () {",
                  "    pm.expect(jsonData.id).to.eql(2);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "PUT",
            "header": [
