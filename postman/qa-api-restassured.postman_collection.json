    {
      "name": "Users - Write (chained)",
      "item": [
        {
          "name": "Create user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status code is 201', function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "",
                  "var jsonData = pm.response.json();",
                  "",
                  "pm.test('response echoes submitted name and job', function () {",
                  "    pm.expect(jsonData.name).to.eql('Morpheus');",
                  "    pm.expect(jsonData.job).to.eql('Leader');",
                  "});",
                  "",
                  "pm.test('id and createdAt are present', function () {",
                  "    pm.expect(jsonData).to.have.property('id');",
                  "    pm.expect(jsonData).to.have.property('createdAt');",
                  "});",
                  "",
                  "// Chain the created user id into a collection/environment variable",
                  "// for reuse by the Update and Delete requests below.",
                  "pm.environment.set('createdUserId', jsonData.id);"
                ]
              }
            }
