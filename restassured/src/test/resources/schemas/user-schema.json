{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Single User Response",
  "type": "object",
  "required": ["id", "firstName", "lastName", "email", "username", "gender", "image"],
  "properties": {
    "id": { "type": "integer" },
    "firstName": { "type": "string" },
    "lastName": { "type": "string" },
    "email": { "type": "string" },
    "username": { "type": "string" },
    "gender": { "type": "string" },
    "image": { "type": "string" }
  }
}
